# Core runtime
LANTERN_CONFIG_PATH=/config/widgets.json
PUBLIC_EXECUTION_NODES=node-1|Node 1 (192.168.1.10)|192.168.1.10,node-2|Node 2 (192.168.1.11)|192.168.1.11
DOCKER_SERVERS=node-1=http://docker-socket-proxy:2375,node-2=http://192.168.1.11:2375
DOCKER_DEFAULT_SERVER=node-1

# Optional auth
LANTERN_AUTH_USER=
LANTERN_AUTH_PASSWORD=
LANTERN_ALLOWED_HOSTS=
LANTERN_CSRF_ORIGIN_CHECK_ENABLED=false
LANTERN_CSRF_ALLOWED_ORIGINS=
LANTERN_CSRF_ALLOW_MISSING_ORIGIN=false

# Probe/test controls
LANTERN_ALLOWED_PROBE_HOSTS=
LANTERN_ALLOW_UNLISTED_PROBE_HOSTS=false
LANTERN_MAX_TEST_BODY_KB=64

# Config/upload/disk limits
LANTERN_MAX_CONFIG_MB=2
LANTERN_UPLOADS_PATH=
LANTERN_MAX_UPLOAD_MB=12
LANTERN_MAX_UPLOAD_BODY_MB=16
LANTERN_MAX_UPLOAD_STORAGE_MB=512
LANTERN_DISK_REFRESH_MIN_MS=2000
LANTERN_BACKUP_DIR=

# OOM/restart alert watcher (host-side)
LANTERN_ALERT_CONTAINER=lantern
LANTERN_ALERT_WEBHOOK_URL=
LANTERN_ALERT_COOLDOWN_SEC=30

# Observability
LANTERN_LOG_LEVEL=info
LANTERN_LOG_QUIET_PATHS=/api/stream,/api/media-image
LANTERN_LOG_REQUEST_SAMPLE_RATE=1
LANTERN_SENTRY_DSN=
LANTERN_SENTRY_ENVIRONMENT=production
LANTERN_SENTRY_RELEASE=
LANTERN_SENTRY_TRACES_SAMPLE_RATE=0

# Integrations
KOMODO_URL=http://localhost:9120
KOMODO_API_KEY=your_key
KOMODO_API_SECRET=your_secret

TECHNITIUM_URL=http://localhost:5380
TECHNITIUM_TOKEN=your_token
TECHNITIUM_TIMEFRAME=LastDay

RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_key
SONARR_URL=http://localhost:8989
SONARR_API_KEY=your_key
READARR_URL=http://localhost:8787
READARR_API_KEY=your_key

PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=your_key
PROFILARR_URL=http://localhost:6868
PROFILARR_API_KEY=your_key

SABNZBD_URL=http://localhost:8080
SABNZBD_API_KEY=your_key
QBITTORRENT_URL=http://localhost:8081
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin

HOME_ASSISTANT_URL=http://localhost:8123
HOME_ASSISTANT_TOKEN=
SCRUTINY_URL=http://localhost:8080
SCRUTINY_API_KEY=
TANDOOR_URL=http://localhost:8080
TANDOOR_API_KEY=
SPEEDTEST_TRACKER_URL=http://localhost:8080
SPEEDTEST_TRACKER_API_KEY=

GRAFANA_URL=http://localhost:3000
AUDIOBOOKSHELF_URL=http://localhost:13378
AUDIOBOOKSHELF_API_KEY=your_key
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your_token
JELLYFIN_URL=http://localhost:8096
JELLYFIN_TOKEN=your_token
JELLYFIN_USER=your_user
SEERR_URL=http://localhost:5055
SEERR_API_KEY=your_key
